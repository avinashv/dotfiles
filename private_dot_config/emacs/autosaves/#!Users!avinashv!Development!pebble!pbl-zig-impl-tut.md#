## 6. Putting It All Together

Let's update `main.zig` to tie everything together:

```zig
// =============================================================================
// main.zig - Pebble Interpreter Entry Point
// =============================================================================

const std = @import("std");
const Parser = @import("parser.zig").Parser;
const Interpreter = @import("interpreter.zig").Interpreter;

pub fn main() !void {
    // Set up allocator
    var gpa = std.heap.GeneralPurposeAllocator(.{}){};
    defer _ = gpa.deinit();
    const allocator = gpa.allocator();

    // Get command line arguments
    const args = try std.process.argsAlloc(allocator);
    defer std.process.argsFree(allocator, args);

    if (args.len < 2) {
        std.debug.print("Usage: pebble <file.pbl>\n", .{});
        return;
    }

    // Read source file
    const filename = args[1];
    const source = std.fs.cwd().readFileAlloc(allocator, filename, 1024 * 1024) catch |err| {
        std.debug.print("Error reading '{s}': {}\n", .{ filename, err });
        return;
    };
    defer allocator.free(source);

    // Parse
    var parser = try Parser.init(source, allocator);
    const parse_result = try parser.parse();
    defer parse_result.instructions.deinit();
    defer parse_result.labels.deinit();

    // Run
    var interp = Interpreter.init(
        parse_result.instructions.items,
        parse_result.labels,
        allocator,
    );
    defer interp.deinit();

    interp.run() catch |err| {
        std.debug.print("Runtime error: {}\n", .{err});
        return;
    };
}
```

