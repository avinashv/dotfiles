;;; ---
;;; Terminal
;;; ---

;; vterm is a fast, fully-featured terminal emulator
;; requires cmake and libvterm (brew install cmake libvterm)
(use-package vterm
  :bind (("C-c v" . vterm)
         ("C-c V" . vterm-other-window))
  :config
  (setq vterm-max-scrollback 10000))

;; toggle vterm as a popup at the bottom
(use-package vterm-toggle
  :bind (("C-`" . vterm-toggle)
         ("C-~" . vterm-toggle-cd))  ;; open in current directory
  :config
  (setq vterm-toggle-fullscreen-p nil)
  (setq vterm-toggle-scope 'project)) ;; one terminal per project

;;; ---
;;; Completion
;;; ---

(use-package company
  :hook (after-init . global-company-mode)
  :config
  (setq company-minimum-prefix-length 1) ;; start completing after 1 char
  (setq company-idle-delay 0.1))         ;; show popup quickly

;;; ---
;;; LSP (Language Server Protocol)
;;; ---

;; lsp-mode auto-installs language servers when you first open a file
;; similar to Mason in nvim
(use-package lsp-mode
  :hook ((python-mode . lsp-deferred)
         (python-ts-mode . lsp-deferred)
         (js-mode . lsp-deferred)
         (js-ts-mode . lsp-deferred)
         (typescript-mode . lsp-deferred)
         (typescript-ts-mode . lsp-deferred)
         (tsx-ts-mode . lsp-deferred)
         (go-mode . lsp-deferred)
         (go-ts-mode . lsp-deferred)
         (rust-mode . lsp-deferred)
         (rust-ts-mode . lsp-deferred)
         (c-mode . lsp-deferred)
         (c-ts-mode . lsp-deferred)
         (css-mode . lsp-deferred)
         (css-ts-mode . lsp-deferred)
         (web-mode . lsp-deferred)
         (lua-mode . lsp-deferred)
         (lua-ts-mode . lsp-deferred)
         (haxe-mode . lsp-deferred))
  :commands (lsp lsp-deferred)
  :init
  (setq lsp-keymap-prefix "C-c l") ;; prefix for LSP commands
  :config
  (setq lsp-auto-guess-root t)     ;; detect project root automatically
  (setq lsp-enable-suggest-server-download t)) ;; prompt to install missing servers

;;; enhanced LSP UI (inline docs, sideline diagnostics)
(use-package lsp-ui
  :after lsp-mode
  :config
  (setq lsp-ui-doc-enable t)      ;; show documentation popups
  (setq lsp-ui-sideline-enable t) ;; show diagnostics iien sideline
  (setq lsp-ui-sideline-show-hover nil)) ;; but don't clutter with hover info

;;; ---
;;; Language Modes (for languages without built-in support)
;;; ---

;; web-mode handles HTML, JSX, and templating languages better than built-in modes
;; also provides auto-closing tags
(use-package web-mode
  :mode (("\\.html?\\'" . web-mode)
         ("\\.jsx\\'" . web-mode)
         ("\\.tsx\\'" . web-mode))
  :config
  (setq web-mode-markup-indent-offset 4)
  (setq web-mode-css-indent-offset 4)
  (setq web-mode-code-indent-offset 4)
  (setq web-mode-enable-auto-pairing t)
  (setq web-mode-enable-auto-closing t)  ;; auto-close tags
  (setq web-mode-enable-current-element-highlight t))

;; lua
(use-package lua-mode
  :mode "\\.lua\\'")

;; haxe
(use-package haxe-mode
  :mode "\\.hx\\'")

;;; ---
;;; Tree-sitter (Syntax Highlighting & Parsing)
;;; ---

;; treesit-auto handles grammar installation and mode remapping
;; e.g., automatically uses python-ts-mode instead of python-mode
(use-package treesit-auto
  :config
  (setq treesit-auto-install 'prompt) ;; ask before installing grammars
  (global-treesit-auto-mode))

;;; ---
;;; Formatting
;;; ---

;; apheleia runs formatters (prettier, black, gofmt, etc.) on save
;; auto-detects which formatter to use based on the file type
;; note: formatters must be installed on your system (npm, pip, brew, etc.)
(use-package apheleia
  :config
  (apheleia-global-mode t))

;;; ---
;;; Discoverability
;;; ---

;; which-key shows available keybindings in a popup
;; helpful for learning Emacs and LSP commands
(use-package which-key
  :config
  (setq which-key-idle-delay 0.3) ;; show quickly
  (which-key-mode))
