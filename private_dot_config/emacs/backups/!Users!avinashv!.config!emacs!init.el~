;;; init.el

;;; ---
;;; Package management
;;; ---

(require 'package)

;;; look for packages in GNU ELPA and MELPA
(setq package-archives
      '(("gnu"    . "https://elpa.gnu.org/packages/")
        ("melpa"  . "https://melpa.org/packages/")))

;;; initialize the package system early
(package-initialize)
(unless package-archive-contents
  (package-refresh-contents))

;;; install use-package for cleaner package declarations
(unless (package-installed-p 'use-package)
  (package-install 'use-package))
(require 'use-package)
(setq use-package-always-ensure t)

;;; ---
;;; Theme & Font
;;; ---

(use-package catppuccin-theme
  :config
  (setq catppuccin-flavor 'mocha)
  (load-theme 'catppuccin :no-confirm))

;;; set font
(set-face-attribute 'default nil :font "MesloLGLDZ Nerd Font Mono" :height 128)

;;; ---
;;; UI
;;; ---

;; in GUI frames, remove the usual chrome for a cleaner interface
;; in terminal frames, these modes may not exist/be relevant, so we guard them
(when (display-graphic-p)
  (set-fringe-mode 10)   ;; give some breathing room
  (tool-bar-mode -1)     ;; remove toolbar icons
  (scroll-bar-mode -1)   ;; remove scrollbars
  (menu-bar-mode -1))    ;; remove menu bar (Cmd-? still works for help/search)

;; small visual defaults that work in both GUI and terminal
(blink-cursor-mode -1)    ;; stop cursor blinking
(column-number-mode 1)    ;; show column number in mode line
(line-number-mode 1)      ;; show line number in mode line (not line numbers in buffer)

;; show line numbers in the left gutter
(global-display-line-numbers-mode 1)

;;; ---
;;; Behavior
;;; ---

(setq inhibit-startup-message t   ;; no splash screen
      ring-bell-function 'ignore) ;; no beeps

(global-auto-revert-mode t) ;; auto-refresh buffers on file change

;;; ensure unique names when matching files exist in a buffer
(require 'uniquify)
(setq uniquify-buffer-name-style 'forward)

;;; performance threshold tweaks
(setq gc-cons-threshold 100000000) ; 100 mb
(setq read-process-output-max (* 1024 1024)) ; 1mb

;;; ---
;;; Editing Defaults
;;; ---

;; use spaces, not tabs
(setq-default indent-tabs-mode nil)

;; a reasonable default width; individual modes may override
(setq-default tab-width 4)

;; helpful when working across files that change on disk
(global-auto-revert-mode 1)

;; remember cursor position in files between sessions
(save-place-mode 1)

;; keep a small "recent files" list
(recentf-mode 1)

;; highlight matching parentheses
(show-paren-mode 1)

;;; ---
;;; Backups/Autosaves
;;; ---

;; by default Emacs creates backup files like "file.txt~" alongside the file
;; this moves them into ~/.config/emacs/backups/
(let ((backup-dir (expand-file-name "backups/" user-emacs-directory))
      (autosave-dir (expand-file-name "autosaves/" user-emacs-directory)))
  (make-directory backup-dir t)
  (make-directory autosave-dir t)
  (setq backup-directory-alist `(("." . ,backup-dir))
        auto-save-file-name-transforms `((".*" ,autosave-dir t))
        auto-save-default t))

;;; ---
;;; Custom.el
;;; ---

;; if you ever use M-x customize, Emacs writes settings to custom-file
;; keeping it separate prevents init.el from being cluttered
(setq custom-file (expand-file-name "custom.el" user-emacs-directory))
(when (file-exists-p custom-file)
  (load custom-file 'noerror 'nomessage))

